# ──────────────────────────────────────────────
#  MyFinances — Environment Variables Template
#  Copy this file to .env.local and fill in the values.
#  Never commit .env.local to git!
# ──────────────────────────────────────────────

# Supabase (required)
# Get these from: https://supabase.com → Your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App access password (required)
# This password protects the entire application.
# Set it to something strong and share it with authorised users only.
ACCESS_PASSWORD=change-me-to-something-strong

# Alpha Vantage API Key (required for market data)
# Get a free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your-alpha-vantage-api-key

# Vercel Cron secret (optional, recommended in production)
# Used to authenticate the daily portfolio snapshot cron job.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Binance API ──────────────────────────────────────────────
# Used to fetch live balances for the Binance Tracker
# Get these from Binance: Profile -> API Management
# IMPORTANT: Check "Enable Reading" only. DO NOT enable Spot/Margin Trading or Withdrawals.
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here